      "흩뿌리기",
      "스트립",
      "산포"
    ],
    "intent": "Strip plot with random jitter: a calculate transform produces a random offset bound to yOffset to reduce overplotting",
    "spec": {
      "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
      "data": {
        "values": []
