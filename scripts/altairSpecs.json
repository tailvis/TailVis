[
  {
    "id": "waterfall_chart",
    "category": "basic",
    "keywords": [
      "waterfall",
      "워터폴",
      "폭포",
      "워터폴차트",
      "cumulative",
      "누적",
      "running total",
      "런닝토탈",
      "bridge",
      "increase",
      "decrease",
      "증감"
    ],
    "intent": "Waterfall chart: a running cumulative total drawn as floating bars. The X axis is the CATEGORY/PERIOD field — one bar per category, sort:null to keep input order. X is NEVER the numeric measure. Each bar spans from the previous cumulative total (_prev) up to the new total (_sum); a window sum over __FIELD__ builds the totals and bars are colored by increase/decrease. Substitute __FIELD__ with the numeric measure column and 'category' with the category/period field (the axis of progression, e.g. month).",
    "spec": {
      "$schema": "https://vega.github.io/schema/vega-lite/v6.json",
      "data": {
        "values": []
      },
      "width": 400,
      "height": 250,
      "transform": [
        {
          "window": [
            {
              "op": "sum",
              "field": "__FIELD__",
              "as": "_sum"
            }
          ],
          "frame": [
            null,
            0
          ]
        },
        {
          "calculate": "datum._sum - datum['__FIELD__']",
          "as": "_prev"
        },
        {
          "calculate": "datum['__FIELD__'] >= 0 ? 'Increase' : 'Decrease'",
          "as": "_dir"
        }
      ],
      "encoding": {
        "x": {
          "field": "category",
          "type": "nominal",
          "sort": null,
          "axis": {
            "labelAngle": 0
          }
        }
      },
      "layer": [
        {
          "mark": {
            "type": "bar",
            "size": 28
          },
          "encoding": {
            "y": {
              "field": "_prev",
              "type": "quantitative",
              "title": "__FIELD__"
            },
            "y2": {
              "field": "_sum"
            },
            "color": {
              "field": "_dir",
              "type": "nominal",
              "scale": {
                "domain": [
                  "Increase",
                  "Decrease"
                ],
                "range": [
                  "#4c78a8",
                  "#e45756"
                ]
              },
              "legend": {
                "title": null
              }
            }
          }
        },
        {
          "mark": {
            "type": "text",
            "dy": -4,
            "fontSize": 10,
            "color": "#333"
          },
          "encoding": {
            "y": {
              "field": "_sum",
              "type": "quantitative"
            },
            "text": {
              "field": "_sum",
              "type": "quantitative",
              "format": ".0f"
            }
          }
        }
      ]
    }
  },
