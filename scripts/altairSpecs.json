          }
        },
        {
          "mark": {
            "type": "text",
            "baseline": "middle"
          },
          "encoding": {
            "x": {
              "field": "Cylinders",
              "type": "ordinal"
            },
            "y": {
              "field": "Origin",
              "type": "ordinal"
            },
            "text": {
              "field": "mean_horsepower",
              "type": "quantitative",
              "format": ".0f"
            },
